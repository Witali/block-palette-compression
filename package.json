{
  "name": "block-palette-compression",
  "version": "1.0.0",
  "private": true,
  "description": "Experimental BPAL block-palette image codec and WebGL texture demos",
  "scripts": {
    "prestart": "npm run generate:bpal-manifest",
    "start": "node tools/serve.js",
    "test": "node tests/run-tests.js",
    "generate:bpal-manifest": "node tools/generate-bpal-manifest.js",
    "benchmark:textures": "python tools/texture_codec_benchmark.py",
    "benchmark:patterns": "node tools/pattern-dictionary-benchmark.js",
    "benchmark:patterns:clic": "node tools/pattern-dictionary-clic-benchmark.js",
    "benchmark:textures:cuda-astc": "python tools/cuda_astc_texture_benchmark.py",
    "benchmark:textures:test": "python -m unittest benchmark.test_metrics benchmark.test_cuda_astc_texture_benchmark"
  }
}
